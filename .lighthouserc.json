{
  "ci": {
    "collect": {
      "startServerCommand": "npx serve dist -l 4322",
      "startServerReadyTimeout": 15000,
      "url": [
        "http://localhost:4322/",
        "http://localhost:4322/blog/",
        "http://localhost:4322/blog/2026-06-14-migrating-to-astro-and-cloudflare-pages/",
        "http://localhost:4322/privacy/"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:seo":           ["error", { "minScore": 0.9 }],
        "categories:performance":   "off",
        "categories:best-practices":"off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
